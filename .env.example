# =============================================================================
# Vietnamese Eden — environment template (NO real secrets)
# Copy to .env.local for local dev. Vercel: set in Project → Environment Variables.
# Full deploy guide: docs/deploy-checklist.md | Variable reference: docs/production-env.md
# =============================================================================

# --- App URL (auth redirects, email links) ---
# Local:
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Vercel Production example:
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# --- Supabase ---
# Local: npm run supabase:start → npm run supabase:status
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional — not required by current app routes (admin scripts only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google OAuth — optional; local uses supabase/config.toml + these vars
# Cloud: configure Google provider in Supabase Dashboard instead
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# --- AI (Breakdown, Remix, Voice) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Local dev: true = mock provider (ignored when NODE_ENV=production, e.g. Vercel)
AI_USE_MOCK=true

# Vercel Production / Preview — use instead of mock:
# AI_USE_MOCK=false
# OPENAI_API_KEY=<set in Vercel Sensitive env>
