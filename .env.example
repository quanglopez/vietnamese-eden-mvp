# =============================================================================
# Vietnamese Eden — environment template (NO real secrets)
# Copy to .env.local for local dev. Vercel: set in Project → Environment Variables.
# Full deploy guide: docs/deploy-checklist.md | Variable reference: docs/production-env.md
# =============================================================================

# --- Pricing / paywall (ALE-174) ---
# false = beta: all features free, no paywall enforcement (default)
# true = show upgrade prompts / tier limits (still no Stripe checkout in MVP)
NEXT_PUBLIC_PRICING_ENABLED=false

# --- App URL (auth redirects, email links) ---
# Local:
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Vercel Production example:
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# --- Supabase ---
# Local: npm run supabase:start → npm run supabase:status
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional — not required by current app routes (admin scripts only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google OAuth — optional; local uses supabase/config.toml + these vars
# Cloud: configure Google provider in Supabase Dashboard instead
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# Feature flag for auth UI in beta/prod environments
GOOGLE_OAUTH_ENABLED=false

# --- AI (Breakdown, Remix, Voice) ---
# Provider: mock (via AI_USE_MOCK dev only) | openai | xiaomi
AI_PROVIDER=xiaomi
AI_MODEL=mimo-v2.5
AI_USE_MOCK=false

# Xiaomi MiMo (production default when AI_PROVIDER=xiaomi)
XIAOMI_API_KEY=your_xiaomi_api_key_here
# Example from Xiaomi MiMo Open Platform docs (set your own; not hardcoded in app):
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
XIAOMI_BASE_URL=your_xiaomi_api_base_url_here

# OpenAI fallback (rollback: AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Local dev: true = mock provider (ignored when NODE_ENV=production, e.g. Vercel)
# AI_USE_MOCK=true

# Vercel Production / Preview — use instead of mock:
# AI_USE_MOCK=false
# AI_PROVIDER=xiaomi
# XIAOMI_API_KEY=<Sensitive>
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
# AI_MODEL=mimo-v2.5

# --- Inngest (background jobs / durable functions) ---
# Cloud: set in Vercel from Inngest dashboard → Manage → Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_API_URL=https://inn.gs/e/your_event_key_here
# Local dev (two terminals):
#   1) npm run dev
#   2) npx inngest-cli@latest dev -u http://localhost:3000/api/inngest
# Dev UI: http://localhost:8288 — send event `test/hello` to trigger helloVietnameseEden

# --- Composio (social auto-publish) ---
# Create account → https://composio.dev → Connect Facebook Page → copy IDs
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_BASE_URL=https://backend.composio.dev/api/v1
COMPOSIO_FACEBOOK_CONNECTED_ACCOUNT_ID=your_facebook_connected_account_id_here
COMPOSIO_FACEBOOK_PAGE_ID=your_facebook_page_id_here


# --- Model benchmark (dev tooling only) ---
# Compare MiMo V2.5 vs DeepSeek V4 Pro on Vietnamese Eden-specific prompts.
# Fill in your real API keys in .env.local before running. Do NOT commit keys.
BENCH_MIMO_BASE_URL=https://api.xiaomimimo.com/v1
BENCH_MIMO_API_KEY=your_bench_mimo_api_key_here
BENCH_MIMO_MODEL=mimo-v2.5-pro

BENCH_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
BENCH_DEEPSEEK_API_KEY=your_bench_deepseek_api_key_here
BENCH_DEEPSEEK_MODEL=deepseek-v4-pro

BENCH_OUTPUT_DIR=benchmarks/results
BENCH_RUNS_PER_TASK=3
BENCH_TIMEOUT_MS=60000
