# App URL (auth redirect)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Supabase — local: supabase start → API URL + anon key from `supabase status`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google OAuth (Supabase Auth — optional for local/cloud)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# AI — Breakdown, Remix, Voice (OpenAI Chat Completions)
# Demo beta: set AI_USE_MOCK=true and skip real OPENAI_API_KEY
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
AI_USE_MOCK=true
