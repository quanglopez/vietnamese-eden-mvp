{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext", "dom"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["@playwright/test"]
  },
  "include": ["browser-use/**/*"],
  "exclude": ["node_modules"]
}
