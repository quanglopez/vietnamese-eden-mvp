# Browser Use QA — Environment variables (copy to .env.browser-use, never commit)
# See docs/browser-use-smoke-guide.md for setup instructions.

# Target URL (required)
#   Production: https://vietnamese-eden-mvp.vercel.app
#   Dev:        http://localhost:3000
BROWSER_USE_BASE_URL=https://vietnamese-eden-mvp.vercel.app

# Test account (create a dedicated test account on the target deployment)
BROWSER_USE_TEST_EMAIL=
BROWSER_USE_TEST_PASSWORD=

# Screenshot output directory (optional, defaults to ./screenshots)
# BROWSER_USE_SCREENSHOT_DIR=./screenshots

# Headless mode (optional, defaults to true)
#   Set to "false" to watch browser during local debugging
# BROWSER_USE_HEADLESS=true

# Browser type (optional, defaults to chromium)
# BROWSER_USE_BROWSER=chromium
